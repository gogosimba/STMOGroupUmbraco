@using ContentModels = Umbraco.Cms.Web.Common.PublishedModels;
@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage<ContentModels.HomePage>
@{
    Layout = "MainLayout.cshtml";
}

<section class="hero">
    <div class="container">
        <h1 style="font-size: 3.5rem; margin-bottom: 20px;">@Model.HeroTitle</h1>
        @{
            var img = Model.Value<IPublishedContent>("heroImage");
            if (img != null)
            {
                <img src="@img.Url()" style="max-width: 100%; margin-top:30px; border-radius:8px;" alt="@Model.HeroTitle" />
            }
        }

  
    </div>
</section>