@using UmbracoSetup_STMOGROUP.Controllers
@using UmbracoSetup_STMOGROUP.Models
@using ContentModels = Umbraco.Cms.Web.Common.PublishedModels;
@using Umbraco.Cms.Web.Common.PublishedModels;
@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage<ContentModels.StandardPage>
@{
    Layout = "MainLayout.cshtml";
}

<div class="container" style="padding: 60px 0; max-width: 800px; margin: 0 auto;">
    <h1 style="margin-bottom: 20px;">@Model.HeroTitle</h1>

    <div class="main-body" style="line-height: 1.6; font-size: 1.1rem; margin-bottom: 40px;">
        @Model.HeroBody
    </div>

    <hr style="border: 0; border-top: 1px solid #eee; margin: 40px 0;" />

    <div id="contact-form" style="background: #fdfdfd; padding: 30px; border: 1px solid #eee; border-radius: 12px; box-shadow: 0 4px 6px rgba(0,0,0,0.05);">
        <h3 style="margin-top: 0;">Kontakta oss</h3>
        <p style="color: #666; margin-bottom: 25px;">Har du frågor? Fyll i formuläret så återkommer vi så snart vi kan.</p>

        @if (TempData["Success"] != null)
        {
            <div style="background: #d4edda; color: #155724; padding: 15px; border-radius: 4px; font-weight: bold;">
                Tack! Ditt meddelande har skickats.
            </div>
        }
        else
        {
            @using (Html.BeginUmbracoForm<ContactSurfaceController>("HandleSubmit"))
            {
                <div style="margin-bottom: 20px;">
                    <label style="display: block; font-weight: bold; margin-bottom: 5px;">Namn</label>
                    @Html.TextBox("Name", null, new { @class = "form-control", style = "width:100%; padding:10px; border: 1px solid #ccc; border-radius: 4px;" })
                    @Html.ValidationMessage("Name", new { @style = "color:red; font-size:12px; display:block; margin-top:5px;" })
                </div>

                <div style="margin-bottom: 20px;">
                    <label style="display: block; font-weight: bold; margin-bottom: 5px;">E-post</label>
                    @Html.TextBox("Email", null, new { @class = "form-control", style = "width:100%; padding:10px; border: 1px solid #ccc; border-radius: 4px;" })
                    @Html.ValidationMessage("Email", new { @style = "color:red; font-size:12px; display:block; margin-top:5px;" })
                </div>

                <div style="margin-bottom: 20px;">
                    <label style="display: block; font-weight: bold; margin-bottom: 5px;">Meddelande</label>
                    @Html.TextArea("Message", null, new { @class = "form-control", style = "width:100%; height:120px; padding:10px; border: 1px solid #ccc; border-radius: 4px;" })
                    @Html.ValidationMessage("Message", new { @style = "color:red; font-size:12px; display:block; margin-top:5px;" })
                </div>

                <button type="submit" style="background: #005bb7; color: white; border: none; padding: 12px 25px; cursor: pointer; border-radius: 6px; font-size: 1rem; font-weight: bold;">
                    Skicka meddelande
                </button>
            }
        }
    </div>
</div>